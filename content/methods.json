[
  {
    "section": "Evidence signal",
    "item": "Strong causal evidence",
    "definition": "Multiple RCTs, high-quality RCT/lottery evidence, or strong quasi-experimental evidence with clear student outcome effects.",
    "urls": [
      "https://ies.ed.gov/ncee/wwc/",
      "https://ies.ed.gov/ncee/wwc/essa",
      "https://ies.ed.gov/ncee/wwc/Handbooks"
    ]
  },
  {
    "section": "Evidence signal",
    "item": "Promising causal/quasi",
    "definition": "Credible lottery, regression discontinuity, difference-in-differences, or well-controlled evidence, but narrower samples or mixed replication.",
    "urls": [
      "https://ies.ed.gov/ncee/wwc/",
      "https://ies.ed.gov/ncee/wwc/essa"
    ]
  },
  {
    "section": "Evidence signal",
    "item": "Mixed/conditional",
    "definition": "Evidence varies by context, outcome, implementation, or student group; may include positive and null/negative findings.",
    "urls": [
      "https://ies.ed.gov/ncee/wwc/"
    ]
  },
  {
    "section": "Evidence signal",
    "item": "Limited/descriptive",
    "definition": "Implementation, trend, or correlational evidence without strong causal identification.",
    "urls": [
      "https://nces.ed.gov/nationsreportcard/",
      "https://cepa.stanford.edu/seda2/data-download"
    ]
  },
  {
    "section": "Evidence signal",
    "item": "Not an outcome intervention",
    "definition": "A research infrastructure, standard, or framework that shapes evidence use but is not itself a student intervention.",
    "urls": [
      "https://ies.ed.gov/ncee/wwc/",
      "https://ies.ed.gov/ncee/wwc/essa"
    ]
  },
  {
    "section": "Design glossary",
    "item": "RCT",
    "definition": "Random assignment to treatment/control; strongest internal validity when implemented and analyzed well.",
    "urls": [
      "https://ies.ed.gov/ncee/wwc/Handbooks",
      "https://ies.ed.gov/ncee/wwc/essa"
    ]
  },
  {
    "section": "Design glossary",
    "item": "Lottery design",
    "definition": "Uses oversubscribed admissions lotteries as random or near-random offers; estimates effects for applicants.",
    "urls": [
      "https://www.mdrc.org/work/projects/new-york-city-small-schools-choice-evaluation",
      "https://nces.ed.gov/use-work/awards/air-early-college-follow-efficacy-study",
      "https://www.nber.org/papers/w28756"
    ]
  },
  {
    "section": "Design glossary",
    "item": "Regression discontinuity",
    "definition": "Compares students/schools just above and below an eligibility cutoff; local to the cutoff.",
    "urls": [
      "https://ies.ed.gov/use-work/resource-library/report/evaluation-report/school-improvement-grants-implementation-and-effectiveness",
      "https://wheelockpolicycenter.org/high-quality-education/ms-read-by-grade-three/"
    ]
  },
  {
    "section": "Design glossary",
    "item": "Difference-in-differences / event study",
    "definition": "Compares pre-post changes for treated vs comparison groups; relies on parallel pre-trends.",
    "urls": [
      "https://academic.oup.com/qje/article-abstract/131/1/157/2461148",
      "https://www.nber.org/papers/w15531"
    ]
  },
  {
    "section": "Design glossary",
    "item": "Matched comparison / virtual control",
    "definition": "Matches treated students/schools to similar untreated units; sensitive to unobserved selection.",
    "urls": [
      "https://credo.stanford.edu/reports/item/national-charter-school-study-iii/",
      "https://www.rand.org/pubs/research_reports/RR1365.html"
    ]
  },
  {
    "section": "Design glossary",
    "item": "Meta-analysis / systematic review",
    "definition": "Aggregates effects across studies; results depend on inclusion rules and comparability.",
    "urls": [
      "https://annenberg.brown.edu/publications/effect-teacher-coaching-instruction-and-achievement-meta-analysis-causal-evidence",
      "https://files.eric.ed.gov/fulltext/ED613847.pdf",
      "https://scholar.usuhs.edu/en/publications/learning-in-one-to-one-laptop-environments-a-meta-analysis-and-re/"
    ]
  },
  {
    "section": "Normalization",
    "item": "Effect sizes",
    "definition": "Convert outcome differences to standard deviations to compare tests and grades; interpret with outcome and age context.",
    "urls": [
      "https://ies.ed.gov/ncee/wwc/Handbooks"
    ]
  },
  {
    "section": "Normalization",
    "item": "Common scales",
    "definition": "Use low-stakes national or harmonized data such as NAEP or SEDA when state tests change.",
    "urls": [
      "https://nces.ed.gov/nationsreportcard/",
      "https://cepa.stanford.edu/seda2/data-download"
    ]
  },
  {
    "section": "Normalization",
    "item": "ITT vs TOT",
    "definition": "Intent-to-treat estimates effect of offer/assignment; treatment-on-treated estimates effect among compliers and needs stronger assumptions.",
    "urls": [
      "https://ies.ed.gov/ncee/wwc/Handbooks"
    ]
  },
  {
    "section": "Normalization",
    "item": "Cost-effectiveness",
    "definition": "Pair credible effect estimates with full implementation costs, not only grant totals or software licenses.",
    "urls": [
      "https://files.eric.ed.gov/fulltext/ED613847.pdf",
      "https://academic.oup.com/qje/article-abstract/131/1/157/2461148"
    ]
  },
  {
    "section": "Core resource",
    "item": "What Works Clearinghouse",
    "definition": "Central federal source for systematic evidence reviews and intervention reports.",
    "urls": [
      "https://ies.ed.gov/ncee/wwc/"
    ]
  },
  {
    "section": "Core resource",
    "item": "ESSA evidence tiers",
    "definition": "Operational evidence tiers for federal education program decisions.",
    "urls": [
      "https://ies.ed.gov/ncee/wwc/essa"
    ]
  },
  {
    "section": "Core resource",
    "item": "NAEP",
    "definition": "Low-stakes nationally representative assessment useful for cross-state comparison and trend checks.",
    "urls": [
      "https://nces.ed.gov/nationsreportcard/"
    ]
  },
  {
    "section": "Core resource",
    "item": "SEDA",
    "definition": "Harmonized district/county achievement and gap data for cross-place comparisons.",
    "urls": [
      "https://cepa.stanford.edu/seda2/data-download"
    ]
  },
  {
    "section": "Core resource",
    "item": "Education Recovery Scorecard",
    "definition": "Harvard/Stanford recovery data linking pandemic recovery patterns, relief, and district outcomes.",
    "urls": [
      "https://educationrecoveryscorecard.org/"
    ]
  },
  {
    "section": "Input variable",
    "item": "Target population",
    "definition": "Use baseline covariates, subgroup indicators, baseline achievement quantiles, and cohort definitions.",
    "urls": [
      "https://cepa.stanford.edu/seda2/data-download",
      "https://nces.ed.gov/nationsreportcard/"
    ]
  },
  {
    "section": "Input variable",
    "item": "Dosage and intensity",
    "definition": "Convert planned exposure to attended exposure; report ITT and treatment-on-treated where possible.",
    "urls": [
      "https://files.eric.ed.gov/fulltext/ED613847.pdf",
      "https://www.rand.org/education-employment-infrastructure/projects/national-summer-learning-project.html",
      "https://edworkingpapers.com/sites/default/files/Kraft%20Novicoff%20-%20Time%20In%20School%20-%20Feb%202024_1.pdf"
    ]
  },
  {
    "section": "Input variable",
    "item": "Staffing ratio and adult contact",
    "definition": "Normalize to effective contact hours and adult qualification level.",
    "urls": [
      "https://www.nber.org/papers/w16381",
      "https://files.eric.ed.gov/fulltext/ED613847.pdf",
      "https://annenberg.brown.edu/publications/effect-teacher-coaching-instruction-and-achievement-meta-analysis-causal-evidence"
    ]
  },
  {
    "section": "Input variable",
    "item": "Curriculum content",
    "definition": "Use common rubrics, curriculum review ratings, lesson artifacts, topic coverage, and teacher usage surveys.",
    "urls": [
      "https://www.rand.org/pubs/research_reports/RR2658.html",
      "https://www.rand.org/pubs/research_reports/RRA134-13.html",
      "https://education.virginia.edu/news-stories/study-knowledge-rich-curriculum-significantly-boosts-reading-scores"
    ]
  },
  {
    "section": "Input variable",
    "item": "Pedagogy and instructional model",
    "definition": "Use validated observation rubrics, video coding, instructional logs, and common categories.",
    "urls": [
      "https://cepr.harvard.edu/met-project",
      "https://annenberg.brown.edu/publications/effect-teacher-coaching-instruction-and-achievement-meta-analysis-causal-evidence",
      "https://eric.ed.gov/?id=EJ353785"
    ]
  },
  {
    "section": "Input variable",
    "item": "Technology role",
    "definition": "Separate access, active academic use, teacher-mediated use, and substitution for in-person instruction.",
    "urls": [
      "https://www.oecd.org/en/publications/students-computers-and-learning_9789264239555-en.html",
      "https://scholar.usuhs.edu/en/publications/learning-in-one-to-one-laptop-environments-a-meta-analysis-and-re/",
      "https://www.frontiersin.org/journals/education/articles/10.3389/feduc.2025.1647573/full"
    ]
  },
  {
    "section": "Input variable",
    "item": "Teacher supports",
    "definition": "Report content focus, active practice, coaching cycles, and alignment to adopted materials.",
    "urls": [
      "https://annenberg.brown.edu/publications/effect-teacher-coaching-instruction-and-achievement-meta-analysis-causal-evidence",
      "https://www.rand.org/pubs/research_reports/RRA134-13.html"
    ]
  },
  {
    "section": "Input variable",
    "item": "Accountability and incentives",
    "definition": "Code stakes, affected grades/subjects, thresholds, consequences, and timing.",
    "urls": [
      "https://www.nber.org/papers/w15531",
      "https://ies.ed.gov/use-work/resource-library/report/evaluation-report/school-improvement-grants-implementation-and-effectiveness",
      "https://www.nber.org/papers/w19403"
    ]
  },
  {
    "section": "Input variable",
    "item": "Governance and choice",
    "definition": "Use lottery offers for ITT where possible; otherwise match on prior achievement and demographics.",
    "urls": [
      "https://credo.stanford.edu/reports/item/national-charter-school-study-iii/",
      "https://www.nber.org/papers/w21839",
      "https://ies.ed.gov/ncee/pubs/20174022/"
    ]
  },
  {
    "section": "Input variable",
    "item": "Time structure",
    "definition": "Convert to active learning time using attendance and instructional-use measures.",
    "urls": [
      "https://edworkingpapers.com/sites/default/files/Kraft%20Novicoff%20-%20Time%20In%20School%20-%20Feb%202024_1.pdf",
      "https://www.rand.org/education-employment-infrastructure/projects/national-summer-learning-project.html"
    ]
  },
  {
    "section": "Input variable",
    "item": "Early childhood quality",
    "definition": "Use classroom quality observations, curriculum indicators, and counterfactual care type.",
    "urls": [
      "https://eric.ed.gov/?id=ED507845",
      "https://my.vanderbilt.edu/tnprekevaluation/",
      "https://www.nber.org/papers/w28756",
      "https://cehd.uchicago.edu/?page_id=958"
    ]
  },
  {
    "section": "Input variable",
    "item": "Whole-child supports",
    "definition": "Track service eligibility, take-up, completion, and schoolwide climate exposure.",
    "urls": [
      "https://casel.org/events/the-evidence-is-clear-an-update-on-research-examining-social-and-emotional-learning/",
      "https://www.rand.org/pubs/research_briefs/RB10051.html",
      "https://www.rand.org/pubs/research_reports/RR3245.html"
    ]
  },
  {
    "section": "Input variable",
    "item": "Finance and resources",
    "definition": "Use real dollars, exposure years, district fixed effects, and cost-effectiveness ratios.",
    "urls": [
      "https://academic.oup.com/qje/article-abstract/131/1/157/2461148",
      "https://educationrecoveryscorecard.org/"
    ]
  },
  {
    "section": "Input variable",
    "item": "Implementation and fidelity",
    "definition": "Separate intent-to-treat, implementation-on-treated, and mediator analyses.",
    "urls": [
      "https://www.mathematica.org/api/sitecore/MediaLibrary/ActualDownload?fileData=NSI+Evaluation+-+Impacts+on+Student+Outcomes+Final+Report.pdf+-+%7B253F094F-163C-4719-BB71-B1D76F5EE4CE%7D&fileId=%7B253F094F-163C-4719-BB71-B1D76F5EE4CE%7D&fileMime=application%2Fpdf&fileName=NSI+Evaluation+-+Impacts+on+Student+Outcomes+Final+Report.pdf",
      "https://www.rand.org/pubs/research_reports/RRA134-13.html",
      "https://ies.ed.gov/use-work/resource-library/report/evaluation-report/reading-first-impact-study-final-report"
    ]
  },
  {
    "section": "Input variable",
    "item": "Counterfactual context",
    "definition": "Use baseline trends, matched controls, cohort fixed effects, and sensitivity analyses.",
