      "https://cepa.stanford.edu/seda2/data-download",
      "https://nces.ed.gov/nationsreportcard/",
      "https://educationrecoveryscorecard.org/"
    ]
  },
  {
    "section": "Outcome",
    "item": "Achievement test scores",
    "definition": "Convert to student-level or grade-level SD; use common NAEP/SEDA scales for cross-state comparisons.",
    "urls": [
      "https://nces.ed.gov/nationsreportcard/",
      "https://cepa.stanford.edu/seda2/data-download",
      "https://ies.ed.gov/ncee/wwc/"
    ]
  },
  {
    "section": "Outcome",
    "item": "Proficiency and cut-score metrics",
    "definition": "Do not equate state proficient with NAEP Proficient; map state standards carefully.",
