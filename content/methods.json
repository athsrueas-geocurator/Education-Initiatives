      "https://cepa.stanford.edu/seda2/data-download"
    ]
  },
  {
    "section": "Outcome",
    "item": "Coursework and grades",
    "definition": "Normalize course titles and rigor; credit inflation can mask learning.",
    "urls": [
      "https://nces.ed.gov/use-work/awards/air-early-college-follow-efficacy-study",
      "https://consortium.uchicago.edu/publications/college-preparatory-curriculum-all-consequences-ninth-grade-coursetaking-algebra-and",
      "https://nces.ed.gov/use-work/evaluations/outcomes-associated-dual-enrollment-programs"
